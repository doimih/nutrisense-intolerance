# Public production domain for SEO/metadata
NEXT_PUBLIC_SITE_URL=https://nustrisense-i.eu

# Shared secret used by backend to sync superadmin password to frontend DB.
# OBLIGATORIU in productie — genereaza cu: openssl rand -hex 32
# Trebuie sa fie identic in ambele containere (frontend + backend).
INTERNAL_SYNC_SECRET=change-me-sync-secret-min32chars!!

# AI Orchestrator (backend container)
# Set OPENAI_API_KEY (or AI_API_KEY) to enable real LLM guidance generation.
# Without this, the frontend falls back to deterministic rule-based guidance.
# OPENAI_API_KEY=sk-...
# AI_PRIMARY_MODEL=gpt-4o
# AI_FALLBACK_MODEL=gpt-4o-mini
# AI_TEMPERATURE=0.4
# AI_MAX_TOKENS=1024

# URL used by frontend route /backend redirect.
# Local machine usage:
# BACKEND_URL=http://localhost:4028

# Production usage:
BACKEND_URL=https://backend.nutriaid.eu
BACKEND_HOST=backend.nutriaid.eu

# Traefik settings (used by docker-compose.traefik.yml)
TRAEFIK_HOST=nustrisense-i.eu
TRAEFIK_HOST_ALT=nutriaid.eu
TRAEFIK_NETWORK=traefik_public
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_ENTRYPOINT_HTTP=web,http
TRAEFIK_ENTRYPOINT_HTTPS=websecure,https
