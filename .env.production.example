# Public production domain
NEXT_PUBLIC_SITE_URL=https://nutrisense-i.eu

# Backend URL used by /backend redirect from frontend
# If backend is on a subdomain, set it accordingly.
BACKEND_URL=https://backend.nutrisense-i.eu

# Required secret used to sign auth session cookies.
# Use a long random value and keep it private.
AUTH_SESSION_SECRET=change_this_to_a_long_random_secret

# Stripe server key. Prefer a restricted key (rk_...) where possible.
STRIPE_RESTRICTED_KEY=rk_live_***

# Optional fallback if you are not using a restricted key.
# STRIPE_SECRET_KEY=sk_live_***

# Stripe webhook secret from Dashboard -> Developers -> Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_***

# Subscription prices used by /api/billing/checkout.
STRIPE_PRICE_BASIC_MONTHLY=price_***
STRIPE_PRICE_PRO_MONTHLY=price_***
STRIPE_PRICE_PRO_PLUS_MONTHLY=price_***
