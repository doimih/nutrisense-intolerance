{
  "name": "nutriaid-intolerances",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:frontend": "next dev -p 3000",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently -k -n frontend,backend -c green,cyan \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "next build",
    "build:backend": "npm --prefix backend run build",
    "build:all": "npm run build && npm run build:backend",
    "start": "cross-env PORT=3000 node .next/standalone/server.js",
    "start:backend": "npm --prefix backend run serve",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e:user-ai": "node scripts/user-ai-e2e.mjs",
    "test:smoke": "node scripts/qa-smoke.mjs",
    "qa": "npm run lint && npm run type-check && npm run build:all && npm run test:unit && npm run test:smoke"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.395.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.8"
  }
}
