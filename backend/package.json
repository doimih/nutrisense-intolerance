{
  "name": "nutriaid",
  "version": "0.1.0",
  "private": true,
  "rocketCritical": {
    "dependencies": [
      "next",
      "react",
      "react-dom",
      "@dhiwise/component-tagger",
      "@tailwindcss/typography",
      "recharts"
    ],
    "devDependencies": [
      "typescript",
      "@types/node",
      "@types/react",
      "@types/react-dom",
      "@typescript-eslint/eslint-plugin",
      "@typescript-eslint/parser",
      "eslint-config-next",
      "tailwindcss",
      "autoprefixer",
      "postcss",
      "eslint",
      "prettier",
      "@netlify/plugin-nextjs"
    ],
    "scripts": [
      "dev",
      "build",
      "start",
      "lint",
      "lint:fix",
      "format",
      "serve",
      "type-check"
    ],
    "warning": "🚨 CRITICAL: DO NOT REMOVE OR MODIFY ABOVE DEPENDENCIES - Required for Next.js 15 TypeScript app functionality"
  },
  "scripts": {
    "dev": "cross-env NEXT_DISABLE_DEVTOOLS=1 next dev -p 4028",
    "build": "next build",
    "start": "cross-env PORT=4028 node .next/standalone/server.js",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "serve": "cross-env PORT=4028 node .next/standalone/server.js",
    "type-check": "tsc --noEmit",
    "test:e2e:superadmin": "node scripts/superadmin-e2e.mjs",
    "test:supervisor": "node --test --experimental-transform-types tests/ai/supervisor/supervisor.test.ts",
    "test:master": "node --test --experimental-transform-types tests/master/master.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@dhiwise/component-tagger": "^1.0.15",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "lucide-react": "^1.7.0",
    "next": "15.5.18",
    "nodemailer": "^8.0.10",
    "nutriaid-intolerances": "file:..",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "react-hook-form": "^7.77.0",
    "recharts": "^2.15.2",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.11.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "10.4.2",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.5.3",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
