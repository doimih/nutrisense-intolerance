# Public production domain
NEXT_PUBLIC_SITE_URL=https://nutriaid-i.eu

# URL-ul intern al frontend-ului (folosit pentru sync parola superadmin)
# In productie: URL-ul public al frontend-ului (ex: https://nutriaid-i.eu)
# In development: http://localhost:3000
FRONTEND_INTERNAL_URL=https://nutriaid-i.eu

# Secretul comun pentru sync-ul de parola intre backend si frontend.
# Trebuie sa fie identic cu INTERNAL_SYNC_SECRET din frontend .env.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SYNC_SECRET=generate_a_long_random_secret
